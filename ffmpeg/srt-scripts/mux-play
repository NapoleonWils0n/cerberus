#!/bin/sh

#===============================================================================
# mux-play - receive a srt stream with mpv
#===============================================================================


#===============================================================================
# script usage
#===============================================================================

usage () {
# if argument passed to function echo it
[ -z "${1}" ] || echo "! ${1}"
# display help
echo "\
$(basename "$0") -i ip -p port"
exit 2
}


#===============================================================================
# error messages
#===============================================================================

INVALID_OPT_ERR='Invalid option:'
REQ_ARG_ERR='requires an argument'


#===============================================================================
# getopts check options passed to script
#===============================================================================

while getopts 'i:p:h' opt
do
  case ${opt} in
     i) ip="${OPTARG}";;
     p) port="${OPTARG}";;
     h) usage;;
     \?) usage "${INVALID_OPT_ERR} ${OPTARG}" 1>&2;;
     :) usage "${INVALID_OPT_ERR} ${OPTARG} ${REQ_ARG_ERR}" 1>&2;;
  esac
done
shift $((OPTIND-1))


#===============================================================================
# defaults
#===============================================================================

# default ip
ip_default='192.168.1.131'

# default port
port_default='6882'


#===============================================================================
# srt_recv function
#===============================================================================

srt_recv () {
srt-live-transmit "srt://${ip:=${ip_default}}:${port:=${port_default}}?mode=listener" file://con | mpv --fs -
}

#===============================================================================
# run srt_recv function
#===============================================================================

srt_recv
