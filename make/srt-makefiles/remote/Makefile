#===============================================================================
# Makefile: mux-remote 
#===============================================================================


#===============================================================================
# Makefile: usage
#
# 1) Edit the 'Videos' section and change videos and timestamps.
# 2) Edit the 'Commands' section and change the ip and port.
# 3) Edit the 'Last video to play' section and set it to the last video.
# 4) Edit the 'Video sequence' so it matches the 'Videos' section.
#===============================================================================


#===============================================================================
# PHONY
#===============================================================================

.PHONY: all clean


#===============================================================================
# Videos
#===============================================================================

#===============================================================================
# VIDEO-1: agent 327
#===============================================================================

VIDEO-1		:= 'https://www.youtube.com/watch?v=mN0zPOpADL4'
VIDEO-1-TIME	:= -s 00:00:08 -t 00:00:16

#===============================================================================
# VIDEO-2: big buck bunny
#===============================================================================

VIDEO-2		:= 'https://www.youtube.com/watch?v=YE7VzlLtp-4'
VIDEO-2-TIME	:= -s 00:01:24 -t 00:01:52

#===============================================================================
# VIDEO-3: charge
#===============================================================================

VIDEO-3		:= 'https://www.youtube.com/watch?v=UXqq0ZvbOnk'
VIDEO-3-TIME	:= -s 00:00:58 -t 00:01:21


#===============================================================================
# Commands
#===============================================================================

#===============================================================================
# Stdout
#===============================================================================

OUTPUT		:= -o -

#===============================================================================
# Srt listener ip address
#===============================================================================

IP		:= 192.168.1.131

#===============================================================================
# Srt listener port
#===============================================================================

PORT		:= 6882


#===============================================================================
# Last video to play
#===============================================================================

TARGET		:= video-3


#===============================================================================
# Default target
#===============================================================================

all: play


#===============================================================================
# Stream all the clips sequentially
#===============================================================================

play:
	@( $(MAKE) $(TARGET) ) | srt-live-transmit file://con srt://$(IP):$(PORT)


#===============================================================================
# Video sequence
#===============================================================================

#===============================================================================
# First video in sequence
#===============================================================================

video-1: 
	mux-remote -u $(VIDEO-1) $(VIDEO-1-TIME) $(OUTPUT)

#===============================================================================
# Second video in sequence
#===============================================================================

video-2: video-1
	mux-remote -u $(VIDEO-2) $(VIDEO-2-TIME) $(OUTPUT)

#===============================================================================
# Last video in sequence
#===============================================================================

video-3: video-2
	mux-remote -u $(VIDEO-3) $(VIDEO-3-TIME) $(OUTPUT)


#===============================================================================
# Clean
#===============================================================================

clean:
	@rm -f /tmp/relay
