#===============================================================================
# Makefile: mux-local
#===============================================================================

#===============================================================================
# Makefile: usage
#
# 1) Edit the 'Videos' section and change videos and timestamps.
# 2) Edit the 'Commands' section and change the ip and port.
# 3) Edit the 'Video sequence' so it matches the 'Videos' section.
#===============================================================================


#===============================================================================
# Phony
#===============================================================================

.PHONY: all clean


#===============================================================================
# Videos
#===============================================================================

#===============================================================================
# VIDEO-1: Big Buck Bunny
#===============================================================================

VIDEO-1		:= ${HOME}/desktop/Big_Buck_Bunny.mkv
VIDEO-1-TIME	:= -s 00:03:05 -t 00:03:20

#===============================================================================
# VIDEO-2: Big Buck Bunny
#===============================================================================

VIDEO-2		:= ${HOME}/desktop/Big_Buck_Bunny.mkv
VIDEO-2-TIME	:= -s 00:05:15 -t 00:05:40

#===============================================================================
# VIDEO-3: Big Buck Bunny
#===============================================================================

VIDEO-3		:= ${HOME}/desktop/Big_Buck_Bunny.mkv
VIDEO-3-TIME	:= -s 00:06:19 -t 00:06:40

#===============================================================================
# VIDEO-4: Charge
#===============================================================================

VIDEO-4		:= ${HOME}/desktop/Charge.mkv
VIDEO-4-TIME	:= -s 00:00:00 -t 00:00:38


#===============================================================================
# Commands
#===============================================================================

#===============================================================================
# Srt listener ip address
#===============================================================================

IP		:= 192.168.1.131

#===============================================================================
# Srt listener port
#===============================================================================

PORT		:= 6882


#===============================================================================
# Default target
#===============================================================================

all: video-4


#===============================================================================
# Video sequence
#===============================================================================

#===============================================================================
# First video in sequence
#===============================================================================

video-1: 
	@mux-local -f $(VIDEO-1) $(VIDEO-1-TIME)

#===============================================================================
# Second video in sequence
#===============================================================================

video-2: video-1
	@mux-local -f $(VIDEO-2) $(VIDEO-2-TIME)

#===============================================================================
# Third video in sequence
#===============================================================================

video-3: video-2
	@mux-local -f $(VIDEO-3) $(VIDEO-3-TIME)

#===============================================================================
# Last video in sequence
#===============================================================================

video-4: video-3
	@mux-local -f $(VIDEO-4) $(VIDEO-4-TIME)


#===============================================================================
# Clean
#===============================================================================

clean:
	@echo 'does nothing'
